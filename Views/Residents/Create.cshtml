@model MgeniTrack.Models.Resident

<form asp-controller="Residents" asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>


    <div class="form-group">
        <label>User</label>
        <select asp-for="UserId" class="form-control" asp-items="ViewBag.UserId"></select>
    </div>

    <div class="form-group">
        <label>Unit</label>
        <select asp-for="UnitId" class="form-control" asp-items="ViewBag.UnitId"></select>
    </div>

    <div style="display:flex; gap:0.75rem; margin-top:1rem;
        padding-top:1rem; border-top:1px solid var(--gray-100);">
        <button type="submit" class="btn btn-primary" style="flex:1;">
            &#10003; Assign Resident
        </button>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
