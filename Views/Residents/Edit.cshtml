@model MgeniTrack.ViewModels.ResidentEditViewModel

@{
    ViewData["Title"] = "Edit Resident";
}

<div class="panel" style="max-width:600px;margin:auto;">

    <h2>Edit Resident</h2>
    <p style="opacity:0.7;">Update resident's assigned unit</p>

    <hr />

    <form asp-action="Edit">

        <input type="hidden" asp-for="ResidentId" />

        <!-- USER (READ ONLY) -->
        <div class="form-group">
            <label>User</label>
            <input class="form-control" value="@Model.UserName" readonly />
        </div>

        <!-- CURRENT UNIT DISPLAY -->
        <div class="form-group">
            <label>Current Unit</label>
            <input class="form-control" value="@Model.CurrentUnitNumber" readonly />
        </div>

        <!-- CHANGE UNIT -->
        <div class="form-group">
            <label>Assign New Unit</label>
            <select asp-for="UnitId" class="form-control" asp-items="ViewBag.UnitId"></select>
            <span asp-validation-for="UnitId" class="text-danger"></span>
        </div>

        <br />

        <div style="display:flex;justify-content:space-between;">
            <a asp-action="Index" class="btn btn-secondary">Back</a>
            <input type="submit" value="Save Changes" class="btn btn-primary" />
        </div>

    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}