@model MgeniTrack.ViewModels.VisitAnalyticsViewModel

@{
    ViewData["Title"] = "Visit Alerts";
}

<partial name="_AnalyticsNav" model="Model" />

<div class="panel">

    <div class="panel-header">
        <div>
            <h2>Long Visit Alerts</h2>
            <p>Suspicious or unusually long visits</p>
        </div>
    </div>

    @if (Model.LongVisitAlerts.Any())
    {
        <div class="alert-list">

            @foreach (var alert in Model.LongVisitAlerts)
            {
                <div class="alert-card">

                    <div class="alert-top">

                        <div>
                            <strong>@alert.VisitorName</strong>
                            <div class="muted">
                                @alert.HouseNumber
                            </div>
                        </div>

                        <div class="badge-red">
                            @alert.DurationMinutes mins
                        </div>

                    </div>

                    <div class="alert-body">

                        <div>
                            Purpose:
                            <strong>@alert.Purpose</strong>
                        </div>

                        <div>
                            Check In:
                            @alert.CheckInTime.ToString("dd MMM yyyy HH:mm")
                        </div>

                        <div class="flag">
                            @alert.Flag
                        </div>

                    </div>

                </div>
            }

        </div>
    }
    else
    {
        <div class="empty-state">
            No alerts detected
        </div>
    }

</div>