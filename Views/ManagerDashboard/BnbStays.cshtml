@model IEnumerable<MgeniTrack.Models.Visit>
@{
    ViewData["Title"] = "BnB Stays — Block C";
}

<div class="page-header">
    <div class="page-header-left">
        <h2>&#127970; BnB Stays — Block C</h2>
        <p>All visits to Block C BnB units</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary">&#8592; Dashboard</a>
</div>

<div class="stats-grid" style="grid-template-columns:repeat(2,1fr);max-width:400px;margin-bottom:1.5rem;">
    <div class="stat-card purple">
        <div class="stat-icon">&#127970;</div>
        <div class="stat-info"><div class="value">@ViewBag.TotalBnb</div><div class="label">Total BnB Stays</div></div>
    </div>
    <div class="stat-card green">
        <div class="stat-icon">&#9899;</div>
        <div class="stat-info"><div class="value">@ViewBag.ActiveBnb</div><div class="label">Currently Staying</div></div>
    </div>
</div>

<div class="panel" style="padding:1rem 1.35rem;margin-bottom:1.25rem;">
    <form asp-action="BnbStays" method="get" style="display:flex;gap:0.75rem;align-items:center;">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control"
               style="max-width:320px;" placeholder="Visitor name or unit..." />
        <button type="submit" class="btn btn-primary">&#128269; Search</button>
        @if (!string.IsNullOrEmpty(ViewBag.Search as string))
        {
            <a asp-action="BnbStays" class="btn btn-secondary">&#10005; Clear</a>
        }
    </form>
</div>

@if (!Model.Any())
{
    <div class="panel"><div class="empty"><span class="empty-icon">&#127970;</span>No BnB stays found.</div></div>
}
else
{
    <div class="table-card">
        <table class="data-table">
            <thead>
                <tr><th>Guest</th><th>Contact</th><th>Unit</th><th>Occupants</th><th>Check-In</th><th>Check-Out</th><th>Duration</th><th>Status</th></tr>
            </thead>
            <tbody>
                @foreach (var v in Model)
                {
                    var dur = v.VisitDuration.HasValue ? (v.VisitDuration.Value >= 60 ? $"{v.VisitDuration.Value/60}h {v.VisitDuration.Value%60}m" : $"{v.VisitDuration.Value}m") : (v.VisitStatus == "CheckedIn" && v.TimeIn.HasValue ? $"{(int)(DateTime.Now - v.TimeIn.Value).TotalMinutes}m (ongoing)" : "—");
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(v.Visitor?.PhotoUrl))
                            {
                                <img src="@v.Visitor.PhotoUrl" style="width:28px;height:28px;border-radius:50%;object-fit:cover;margin-right:0.4rem;vertical-align:middle;" />
                            }
                            <strong>@(v.Visitor?.FullName ?? "—")</strong>
                            <div style="font-size:0.72rem;color:var(--gray-400);">@(v.Visitor?.IdNumber ?? "")</div>
                        </td>
                        <td style="font-size:0.8rem;">@(v.Visitor?.ContactNumber ?? "—")</td>
                        <td><span class="badge badge-purple">@(v.HouseNumber ?? "—")</span></td>
                        <td style="text-align:center;">@(v.NumberOfOccupants ?? 1)</td>
                        <td style="font-size:0.8rem;">@(v.TimeIn?.ToString("dd MMM, HH:mm") ?? "—")</td>
                        <td style="font-size:0.8rem;">@(v.TimeOut?.ToString("dd MMM, HH:mm") ?? "—")</td>
                        <td><span class="duration">@dur</span></td>
                        <td><span class="badge @(v.VisitStatus == "CheckedIn" ? "badge-in" : "badge-out")">@(v.VisitStatus == "CheckedIn" ? "Staying" : "Checked Out")</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

