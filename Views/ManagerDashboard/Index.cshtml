@{
    ViewData["Title"] = "Manager Dashboard";
}

<div class="page-header">
    <div class="page-header-left">
        <h2>&#127963; Property Manager Dashboard</h2>
        <p>Manage residents and visitor invitations — @DateTime.Now.ToString("dddd, dd MMMM yyyy")</p>
    </div>
</div>

<div class="stats-grid">
    <div class="stat-card blue">
        <div class="stat-icon">&#127968;</div>
        <div class="stat-info">
            <div class="value">@ViewBag.TotalResidents</div>
            <div class="label">Total Residents</div>
        </div>
    </div>
    <div class="stat-card green">
        <div class="stat-icon">&#128140;</div>
        <div class="stat-info">
            <div class="value">@ViewBag.TotalInvitations</div>
            <div class="label">Total Invitations</div>
        </div>
    </div>
    <div class="stat-card orange">
        <div class="stat-icon">&#9203;</div>
        <div class="stat-info">
            <div class="value">@ViewBag.PendingInvitations</div>
            <div class="label">Pending</div>
        </div>
    </div>
    <div class="stat-card teal">
        <div class="stat-icon">&#128118;</div>
        <div class="stat-info">
            <div class="value">@ViewBag.ArrivedToday</div>
            <div class="label">Arrived Today</div>
        </div>
    </div>
</div>

<div class="quick-actions">
    <a asp-controller="Residents" asp-action="Index" class="btn btn-secondary">&#128101; All Residents</a>
    <a asp-controller="VisitorInvitations" asp-action="Index" class="btn btn-secondary">&#128203; All Invitations</a>
</div>

<div class="panels-2col">
    <div class="panel">
        <div class="panel-title">&#128337; Recent Invitations</div>
        @{
            var invitations = ViewBag.RecentInvitations as List<MgeniTrack.Models.VisitorInvitation>;
        }
        @if (invitations != null && invitations.Any())
        {
            <table class="data-table">
                <thead>
                    <tr><th>Visitor</th><th>Resident</th><th>Expected</th><th>Status</th></tr>
                </thead>
                <tbody>
                    @foreach (var inv in invitations)
                    {
                        var bc = inv.VisitStatus switch
                        {
                            "Pending" => "badge-pending",
                            "Arrived" => "badge-arrived",
                            "Expired" => "badge-expired",
                            "Cancelled" => "badge-cancelled",
                            _ => "badge-pending"
                        };
                        <tr>
                            <td><strong>@inv.VisitorName</strong></td>
                            <td>@(inv.Resident?.User?.Firstname ?? "—")</td>
                            <td>@(inv.ExpectedDate?.ToString("dd MMM") ?? "—")</td>
                            <td><span class="badge @bc">@inv.VisitStatus</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {

            <div class="empty">No invitations yet.</div>
        }
    </div>

    <div class="panel">
        <div class="panel-title">&#127968; Residents</div>
        @{
            var residents = ViewBag.Residents as List<MgeniTrack.Models.Resident>;
        }
        @if (residents != null && residents.Any())
        {
            @foreach (var r in residents)
            {
                <div class="resident-row">
                    <div>
                        <div class="res-name">@(r.User?.Firstname) @(r.User?.Secondname)</div>
                        <div class="res-meta">@(r.VisitorInvitations?.Count ?? 0) invitation(s)</div>
                    </div>
                    <span class="res-house">@r.HouseNumber</span>
                </div>
            }
        }
        else
        {
            <div class="empty">No residents registered.</div>
        }
    </div>
</div>
