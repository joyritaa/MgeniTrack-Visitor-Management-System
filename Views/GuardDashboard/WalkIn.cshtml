@model MgeniTrack.ViewModels.WalkInViewModel
@{
    ViewData["Title"] = "Walk-In Check-In";
    var occupiedUnits = ViewBag.OccupiedUnits as List<MgeniTrack.Models.Unit> ?? new();
    var blockA = occupiedUnits.Where(u => u.Block == "A").ToList();
    var blockB = occupiedUnits.Where(u => u.Block == "B").ToList();
    var blockC = occupiedUnits.Where(u => u.Block == "C").ToList();
}

<div class="page-header">
    <div class="page-header-left">
        <h2>&#128100; Walk-In Check-In</h2>
        <p>Manual check-in for visitors without a pre-registered invitation</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary">&#8592; Dashboard</a>
</div>

<div style="display:grid;grid-template-columns:1.4fr 1fr;gap:1.5rem;align-items:start;">
    <div class="form-card" style="max-width:100%;">
        <div class="panel-title">&#9999; Visitor Details</div>

        <form asp-action="WalkIn" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="form-group">
                <label asp-for="VisitorName"></label>
                <input asp-for="VisitorName" class="form-control" placeholder="Full name" autofocus />
                <span asp-validation-for="VisitorName" class="text-danger"></span>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
                <div class="form-group">
                    <label asp-for="IdNumber"></label>
                    <input asp-for="IdNumber" class="form-control" placeholder="National ID / Passport" />
                </div>
                <div class="form-group">
                    <label asp-for="ContactNumber"></label>
                    <input asp-for="ContactNumber" class="form-control" placeholder="07XX XXX XXX" />
                </div>
            </div>

           <!--photo upload with camera-->
            <div class="form-group">
                <label>Visitor Photo <span style="color:var(--gray-400);font-weight:400;">(optional)</span></label>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 0.5rem;">
                    <div>
                        <input type="file" id="photoFileInput" name="visitorPhoto" accept="image/*" class="form-control"
                               style="padding:0.5rem;" onchange="previewPhoto(this)" />
                        <small style="color: var(--gray-500);">Upload from device</small>
                    </div>
                    <div>
                        <button type="button" class="btn btn-secondary" onclick="captureFromCamera()" style="width: 100%;">
                            📷 Capture Photo
                        </button>
                        <small style="color: var(--gray-500);">Use device camera</small>
                    </div>
                </div>
                <img id="photoPreview" src="" style="display:none;width:80px;height:80px;
                     border-radius:50%;object-fit:cover;margin-top:0.5rem;
                     border:2px solid var(--blue-200);" />
            </div>

            <!--unit selection only occupied ones-->
            <div class="form-group">
                <label asp-for="HouseNumber"></label>
                <select asp-for="HouseNumber" class="form-control" id="houseSelect"
                        onchange="onUnitChange(this.value)">
                    <option value="">— Select occupied unit —</option>
                    @if (blockA.Any())
                    {
                        <optgroup label="Block A — Residential (@blockA.Count occupied)">
                            @foreach (var u in blockA)
                            {
                                <option value="@u.UnitNumber">@u.UnitNumber</option>
                            }
                        </optgroup>
                    }
                    @if (blockB.Any())
                    {
                        <optgroup label="Block B — Residential (@blockB.Count occupied)">
                            @foreach (var u in blockB)
                            {
                                <option value="@u.UnitNumber">@u.UnitNumber</option>
                            }
                        </optgroup>
                    }
                    @if (blockC.Any())
                    {
                        <optgroup label="Block C — BnB (@blockC.Count occupied)">
                            @foreach (var u in blockC)
                            {
                                <option value="@u.UnitNumber">@u.UnitNumber</option>
                            }
                        </optgroup>
                    }
                </select>
                <span asp-validation-for="HouseNumber" class="text-danger"></span>
                <small id="unitInfo" style="font-size:0.75rem;margin-top:0.25rem;display:block;"></small>
            </div>

            <div class="form-group">
                <label asp-for="PurposeOfVisit"></label>
                <select asp-for="PurposeOfVisit" class="form-control" id="purposeSelect">
                    <option value="">— Select purpose —</option>
                    <option value="Personal Visit">Personal Visit</option>
                    <option value="Family">Family</option>
                    <option value="Delivery">Delivery</option>
                    <option value="Maintenance / Repair">Maintenance / Repair</option>
                    <option value="Business">Business</option>
                    <option value="BnB Stay">BnB Stay (Block C)</option>
                    <option value="Other">Other</option>
                </select>
                <span asp-validation-for="PurposeOfVisit" class="text-danger"></span>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
                <div class="form-group">
                    <label asp-for="NumberOfOccupants"></label>
                    <input asp-for="NumberOfOccupants" type="number" class="form-control" min="1" max="20" />
                </div>
                <div class="form-group">
                    <label asp-for="CarRegistration"></label>
                    <input asp-for="CarRegistration" class="form-control" placeholder="KCA 123A (optional)" />
                </div>
            </div>

            <div style="display:flex;gap:0.75rem;margin-top:1rem;padding-top:1rem;border-top:1px solid var(--gray-100);">
                <button type="submit" class="btn btn-primary" style="flex:1;">&#9989; Check In</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>

<!--info panel-->
    <div>
        <div class="panel" style="background:var(--blue-50);border-color:var(--blue-200);margin-bottom:1rem;">
            <div class="panel-title" style="color:var(--blue-600);">&#127968; Building — Occupied Units</div>
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem;text-align:center;">
                <div>
                    <div style="font-size:1.5rem;font-weight:800;color:var(--blue-700);">@blockA.Count</div>
                    <div style="font-size:0.72rem;color:var(--blue-500);">Block A</div>
                </div>
                <div>
                    <div style="font-size:1.5rem;font-weight:800;color:var(--blue-700);">@blockB.Count</div>
                    <div style="font-size:0.72rem;color:var(--blue-500);">Block B</div>
                </div>
                <div>
                    <div style="font-size:1.5rem;font-weight:800;color:var(--purple);">@blockC.Count</div>
                    <div style="font-size:0.72rem;color:var(--purple);">Block C (BnB)</div>
                </div>
            </div>
            <div style="margin-top:0.75rem;font-size:0.78rem;color:var(--blue-600);text-align:center;">
                Only occupied units shown. Vacant units are not selectable.
            </div>
        </div>
        <div class="panel" style="background:var(--warning-light);border-color:#fcd34d;">
            <div class="panel-title" style="color:var(--warning-dark);">&#128274; Checklist</div>
            <ul style="font-size:0.82rem;color:var(--warning-dark);padding-left:1.2rem;line-height:2.1;">
                <li>Verify visitor's ID document</li>
                <li>Confirm resident is expecting them</li>
                <li>Block C = BnB — confirm booking reference</li>
                <li>Take a photo if possible</li>
                <li>Record car registration if applicable</li>
            </ul>
        </div>
        <div class="panel">
            <a asp-controller="VisitorInvitations" asp-action="PendingList"
               class="btn btn-primary" style="width:100%;justify-content:center;">
                &#128203; Check Pre-Registered Instead
            </a>
        </div>
    </div>
</div>

<script>
    let cameraStream = null;

    function previewPhoto(input) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = function(e) {
                var img = document.getElementById('photoPreview');
                img.src = e.target.result;
                img.style.display = 'block';
            };
            reader.readAsDataURL(input.files[0]);
        }
    }

    function captureFromCamera() {
        // Check if camera modal exists, if not create it
        let modal = document.getElementById('cameraModal');
        if (!modal) {
            createCameraModal();
            modal = document.getElementById('cameraModal');
        }
        modal.style.display = 'block';
        startCamera();
    }

    function createCameraModal() {
        const modalHTML = `
            <div id="cameraModal" class="modal" style="display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.4);">
                <div class="modal-content" style="background-color: #fefefe; margin: 10% auto; padding: 20px; border: 1px solid #888; width: 90%; max-width: 500px; border-radius: 8px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                        <h3 style="margin: 0;">Capture Visitor Photo</h3>
                        <span class="close" onclick="closeCameraModal()" style="font-size: 28px; font-weight: bold; cursor: pointer; color: #aaa;">×</span>
                    </div>
                    <video id="cameraVideo" style="width: 100%; height: auto; border-radius: 4px; margin-bottom: 1rem; background: #000;"></video>
                    <canvas id="photoCanvas" style="display: none;"></canvas>
                    <div style="display: flex; gap: 0.5rem; justify-content: space-between;">
                        <button type="button" class="btn btn-primary" onclick="capturePhoto()" style="flex: 1;">📸 Capture</button>
                        <button type="button" class="btn btn-secondary" onclick="closeCameraModal()" style="flex: 1;">Close</button>
                    </div>
                </div>
            </div>
        `;
        document.body.insertAdjacentHTML('beforeend', modalHTML);
    }

    function startCamera() {
        const video = document.getElementById('cameraVideo');
        navigator.mediaDevices.getUserMedia({ 
            video: { facingMode: 'user' },
            audio: false
        }).then(stream => {
            cameraStream = stream;
            video.srcObject = stream;
            video.play();
        }).catch(err => {
            alert('Unable to access camera: ' + err.message);
            closeCameraModal();
        });
    }

    function capturePhoto() {
        const video = document.getElementById('cameraVideo');
        const canvas = document.getElementById('photoCanvas');
        const ctx = canvas.getContext('2d');

        canvas.width = video.videoWidth;
        canvas.height = video.videoHeight;
        ctx.drawImage(video, 0, 0);

        canvas.toBlob(blob => {
            const file = new File([blob], 'captured_photo.jpg', { type: 'image/jpeg' });
            const dataTransfer = new DataTransfer();
            dataTransfer.items.add(file);
            document.getElementById('photoFileInput').files = dataTransfer.files;

            // Show preview
            const reader = new FileReader();
            reader.onload = function(e) {
                var img = document.getElementById('photoPreview');
                img.src = e.target.result;
                img.style.display = 'block';
            };
            reader.readAsDataURL(blob);

            closeCameraModal();
        }, 'image/jpeg', 0.95);
    }

    function closeCameraModal() {
        const modal = document.getElementById('cameraModal');
        if (modal) modal.style.display = 'none';

        if (cameraStream) {
            cameraStream.getTracks().forEach(track => track.stop());
            cameraStream = null;
        }
    }

    // Close modal when clicking outside of it
    window.onclick = function(event) {
        const modal = document.getElementById('cameraModal');
        if (modal && event.target === modal) {
            closeCameraModal();
        }
    }

    function onUnitChange(unit) {
        var info    = document.getElementById('unitInfo');
        var purpose = document.getElementById('purposeSelect');
        if (!unit) { info.textContent = ''; return; }
        var block = unit[0];
        if (block === 'C') {
            info.innerHTML = '<span style="color:var(--purple);font-weight:600;">&#127970; BnB Unit — purpose auto-set to BnB Stay</span>';
            purpose.value  = 'BnB Stay';
        } else {
            info.innerHTML = '<span style="color:var(--blue-600);">&#127968; Residential Unit — Block ' + block + '</span>';
            if (purpose.value === 'BnB Stay') purpose.value = '';
        }
    }
</script>



@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}