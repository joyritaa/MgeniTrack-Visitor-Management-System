@using MgeniTrack.Helpers
@model MgeniTrack.ViewModels.WalkInViewModel

@{
    ViewData["Title"] = "Manual Walk-In Check-In";
    var grouped = ViewBag.HouseNumbers as Dictionary<string, List<string>>
                  ?? HouseNumberHelper.GetGrouped();
}

<div class="page-header">
    <div class="page-header-left">
        <h2>&#128100; Manual Walk-In Check-In</h2>
        <p>Register a visitor arriving without a pre-registered invitation</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary">&#8592; Dashboard</a>
</div>

<div style="display:grid; grid-template-columns:1fr 1fr; gap:1.5rem; align-items:start;">

    <div class="form-card" style="max-width:100%;">
        <div style="font-size:0.73rem; font-weight:700; text-transform:uppercase;
                    letter-spacing:0.1em; color:var(--gray-400);
                    padding-bottom:0.85rem; margin-bottom:1.25rem;
                    border-bottom:1px solid var(--gray-100);">
            &#9999; Visitor Details
        </div>

        <form asp-action="WalkIn" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="form-group">
                <label asp-for="VisitorName"></label>
                <input asp-for="VisitorName" class="form-control"
                       placeholder="e.g. John Kamau" autofocus />
                <span asp-validation-for="VisitorName" class="text-danger"></span>
            </div>

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
                <div class="form-group">
                    <label asp-for="IdNumber"></label>
                    <input asp-for="IdNumber" class="form-control"
                           placeholder="National ID or Passport" />
                    <span asp-validation-for="IdNumber" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="ContactNumber"></label>
                    <input asp-for="ContactNumber" class="form-control"
                           placeholder="07XX XXX XXX" />
                    <span asp-validation-for="ContactNumber" class="text-danger"></span>
                </div>
            </div>

            <!-- House number — grouped dropdown by block -->
            <div class="form-group">
                <label asp-for="HouseNumber"></label>
                <select asp-for="HouseNumber" class="form-control" id="houseSelect"
                        onchange="autoDetectPurpose(this.value)">
                    <option value="">— Select unit —</option>
                    @foreach (var group in grouped)
                    {
                        <optgroup label="@group.Key">
                            @foreach (var unit in group.Value)
                            {
                                <option value="@unit">@unit</option>
                            }
                        </optgroup>
                    }
                </select>
                <span asp-validation-for="HouseNumber" class="text-danger"></span>
                <small id="blockLabel" style="color:var(--blue-600); font-size:0.75rem; margin-top:0.25rem; display:block;"></small>
            </div>

            <!-- Purpose of visit -->
            <div class="form-group">
                <label asp-for="PurposeOfVisit"></label>
                <select asp-for="PurposeOfVisit" class="form-control" id="purposeSelect">
                    <option value="">— Select purpose —</option>
                    <option value="Personal Visit">Personal Visit</option>
                    <option value="Family">Family</option>
                    <option value="Delivery">Delivery</option>
                    <option value="Maintenance / Repair">Maintenance / Repair</option>
                    <option value="Business">Business</option>
                    <option value="BnB Stay">BnB Stay (Block C)</option>
                    <option value="Other">Other</option>
                </select>
                <span asp-validation-for="PurposeOfVisit" class="text-danger"></span>
            </div>

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
                <div class="form-group">
                    <label asp-for="NumberOfOccupants"></label>
                    <input asp-for="NumberOfOccupants" type="number"
                           class="form-control" min="1" max="20" />
                    <span asp-validation-for="NumberOfOccupants" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="CarRegistration"></label>
                    <input asp-for="CarRegistration" class="form-control"
                           placeholder="e.g. KCA 123A (optional)" />
                    <span asp-validation-for="CarRegistration" class="text-danger"></span>
                </div>
            </div>

            <div style="display:flex; gap:0.75rem; margin-top:1rem;
                        padding-top:1rem; border-top:1px solid var(--gray-100);">
                <button type="submit" class="btn btn-primary" style="flex:1;">
                    &#9989; Check In Visitor
                </button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>

    <!-- Info panel -->
    <div>
        <div class="panel" style="background:var(--blue-50); border-color:var(--blue-200); margin-bottom:1rem;">
            <div class="panel-title" style="color:var(--blue-500);">&#127968; Building Layout</div>
            <div style="font-size:0.83rem; color:var(--blue-700); line-height:2.1;">
                <div>
                    <strong>Block A</strong> — Residential &nbsp;
                    <span style="color:var(--gray-400);">A101–A610 (60 units)</span>
                </div>
                <div>
                    <strong>Block B</strong> — Residential &nbsp;
                    <span style="color:var(--gray-400);">B101–B610 (60 units)</span>
                </div>
                <div>
                    <strong>Block C</strong> — BnB Units &nbsp;
                    <span style="color:var(--gray-400);">C101–C610 (60 units)</span>
                </div>
                <div style="margin-top:0.5rem; font-size:0.78rem; color:var(--blue-500);">
                    Unit format: [Block][Floor][Unit01–10]<br />
                    e.g. A201 = Block A, Floor 2, Unit 1
                </div>
            </div>
        </div>

        <div class="panel" style="background:var(--warning-light); border-color:#fcd34d;">
            <div class="panel-title" style="color:var(--warning-dark);">&#128274; Guard Checklist</div>
            <ul style="font-size:0.82rem; color:var(--warning-dark); padding-left:1.2rem; line-height:2.1;">
                <li>Verify visitor's ID document</li>
                <li>Confirm with resident before entry</li>
                <li>For Block C — confirm BnB booking</li>
                <li>Record car reg if arrived by vehicle</li>
                <li>Note number of occupants accurately</li>
            </ul>
        </div>

        <div class="panel">
            <a asp-controller="VisitorInvitations" asp-action="PendingList"
               class="btn btn-primary" style="width:100%; justify-content:center;">
                &#128203; Check Pre-Registered Visitors Instead
            </a>
        </div>
    </div>
</div>

<script>
    function autoDetectPurpose(unit) {
        var label  = document.getElementById('blockLabel');
        var purpose = document.getElementById('purposeSelect');

        if (!unit) { label.textContent = ''; return; }

        var block = unit[0];
        if (block === 'A') {
            label.textContent = 'Block A — Residential';
            label.style.color = 'var(--blue-600)';
        } else if (block === 'B') {
            label.textContent = 'Block B — Residential';
            label.style.color = 'var(--blue-600)';
        } else if (block === 'C') {
            label.textContent = 'Block C — BnB Unit (auto-set purpose to BnB Stay)';
            label.style.color = 'var(--success)';
            purpose.value = 'BnB Stay';
        }
    }
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
