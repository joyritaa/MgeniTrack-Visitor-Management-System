@{
    ViewData["Title"] = "Guard Dashboard";
}

<div class="page-header">
    <div class="page-header-left">
        <h2>&#128737; Guard Dashboard</h2>
        <p>Active visits and check-in operations — @DateTime.Now.ToString("dddd, dd MMMM yyyy HH:mm")</p>
    </div>
</div>

<!-- Stats -->
<div class="stats-grid">
    <div class="stat-card orange">
        <div class="stat-icon">&#128682;</div>
        <div class="stat-info">
            <div class="value">@ViewBag.CurrentlyInside</div>
            <div class="label">Currently Inside</div>
        </div>
    </div>
    <div class="stat-card blue">
        <div class="stat-icon">&#128197;</div>
        <div class="stat-info">
            <div class="value">@ViewBag.TodayVisitCount</div>
            <div class="label">Visits Today</div>
        </div>
    </div>
    <div class="stat-card green">
        <div class="stat-icon">&#9989;</div>
        <div class="stat-info">
            <div class="value">@ViewBag.CheckedOutToday</div>
            <div class="label">Checked Out Today</div>
        </div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">&#9989; @TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">&#9888; @TempData["Error"]</div>
}

<!-- Quick Actions -->
<div class="quick-actions">
    <a asp-controller="VisitorInvitations" asp-action="PendingList"
       class="btn btn-primary">
        &#128203; Verify Pre-Registered Visitor
    </a>
    <a asp-action="WalkIn" class="btn btn-secondary">
        &#128100; Manual Walk-In Check-In
    </a>
    <a asp-controller="Visits" asp-action="Index" class="btn btn-secondary">
        &#128203; All Visit Records
    </a>
</div>

<!-- Active Visits Table -->
<div class="panel">
    <div class="panel-title">&#9899; Visitors Currently Inside — Click "Check Out" to record exit</div>

    @{
        var activeVisits = ViewBag.ActiveVisits as List<MgeniTrack.Models.Visit>;
    }

    @if (activeVisits != null && activeVisits.Any())
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Visitor Name</th>
                    <th>House</th>
                    <th>Purpose</th>
                    <th>Method</th>
                    <th>Time In</th>
                    <th>Duration</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var v in activeVisits)
                {
                    var mins = v.TimeIn.HasValue
                    ? (int)(DateTime.Now - v.TimeIn.Value).TotalMinutes : 0;
                    var dur = mins >= 60
                    ? $"{mins / 60}h {mins % 60}m" : $"{mins}m";
                    <tr>
                        <td><strong>@(v.Visitor?.FullName ?? "—")</strong></td>
                        <td>
                            <span class="badge badge-blue">@(v.HouseNumber ?? "—")</span>
                        </td>
                        <td>@(v.PurposeOfVisit ?? "—")</td>
                        <td>
                            <span class="badge @(v.CheckInMethod == "QR" ? "badge-blue" : "badge-gray")">
                                @(v.CheckInMethod ?? "Manual")
                            </span>
                        </td>
                        <td>@(v.TimeIn?.ToString("HH:mm") ?? "—")</td>
                        <td><span class="duration">@dur</span></td>
                        <td><span class="badge badge-in">&#9679; Inside</span></td>
                        <td>
                            <!-- ✅ FIXED: Points to GuardDashboard/CheckOut, not Visits/Edit -->
                            <a asp-action="CheckOut"
                               asp-route-visitId="@v.VisitId"
                               class="btn btn-danger"
                               style="padding:0.35rem 0.8rem; font-size:0.78rem;">
                                &#128682; Check Out
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="empty">
            <span class="empty-icon">&#127968;</span>
            No visitors currently inside the premises.
        </div>
    }
</div>
