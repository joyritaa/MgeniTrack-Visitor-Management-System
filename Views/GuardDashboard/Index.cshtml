@{
    ViewData["Title"] = "Guard Dashboard";
    var shift = ViewBag.Shift as string ?? "—";
    var guardName = ViewBag.GuardName as string ?? "Guard";
}

<div class="page-header">
    <div class="page-header-left">
        <h2>&#128737; Guard Dashboard</h2>
        <p>
            @DateTime.Now.ToString("dddd, dd MMMM yyyy HH:mm") &nbsp;•&nbsp;
            <span class="badge @(shift == "Day" ? "badge-orange" : "badge-blue")">
                @(shift == "Day" ? "☀️" : "🌙") @shift Shift
            </span>
        </p>
    </div>
    <div style="display:flex;gap:0.65rem;">
        <a asp-action="WalkIn" class="btn btn-primary">&#43; Walk-In Check-In</a>
        <a asp-controller="VisitorInvitations" asp-action="PendingList" class="btn btn-secondary">&#128203; Pre-Registered</a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">&#9989; @TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">&#9888; @TempData["Error"]</div>
}

<div class="stats-grid">
    <div class="stat-card orange">
        <div class="stat-icon">&#128682;</div>
        <div class="stat-info"><div class="value">@ViewBag.CurrentlyInside</div><div class="label">Currently Inside</div></div>
    </div>
    <div class="stat-card blue">
        <div class="stat-icon">&#128197;</div>
        <div class="stat-info"><div class="value">@ViewBag.TodayVisitCount</div><div class="label">Visits Today</div></div>
    </div>
    <div class="stat-card green">
        <div class="stat-icon">&#9989;</div>
        <div class="stat-info"><div class="value">@ViewBag.CheckedOutToday</div><div class="label">Checked Out Today</div></div>
    </div>
</div>

<!-- Active Visits with inline search -->
<div class="panel">
    <div style="display:flex;align-items:center;justify-content:space-between;
                padding-bottom:0.85rem;margin-bottom:1rem;border-bottom:1px solid var(--gray-100);">
        <span class="panel-title" style="border:none;padding:0;margin:0;">&#9899; Currently Inside</span>
        <a asp-action="ActiveVisits" style="font-size:0.78rem;color:var(--blue-600);font-weight:600;">
            View All &amp; Search →
        </a>
    </div>

    @{
        var activeVisits = ViewBag.ActiveVisits as List<MgeniTrack.Models.Visit>;
    }
    @if (activeVisits != null && activeVisits.Any())
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Visitor</th>
                    <th>House</th>
                    <th>Purpose</th>
                    <th>Method</th>
                    <th>Time In</th>
                    <th>Duration</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var v in activeVisits.Take(10))
                {
                    var mins = v.TimeIn.HasValue ? (int)(DateTime.Now - v.TimeIn.Value).TotalMinutes : 0;
                    var dur = mins >= 60 ? $"{mins / 60}h {mins % 60}m" : $"{mins}m";
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(v.Visitor?.PhotoUrl))
                            {
                                <img src="@v.Visitor.PhotoUrl" style="width:28px;height:28px;border-radius:50%;object-fit:cover;margin-right:0.4rem;vertical-align:middle;" />
                            }
                            <strong>@(v.Visitor?.FullName ?? "—")</strong>
                        </td>
                        <td><span class="badge badge-blue">@(v.HouseNumber ?? "—")</span></td>
                        <td>@(v.PurposeOfVisit ?? "—")</td>
                        <td><span class="badge @(v.CheckInMethod == "QR" ? "badge-blue" : "badge-gray")">@(v.CheckInMethod ?? "Manual")</span></td>
                        <td>@(v.TimeIn?.ToString("HH:mm") ?? "—")</td>
                        <td><span class="duration">@dur</span></td>
                        <td>
                            <a asp-action="CheckOut" asp-route-visitId="@v.VisitId"
                               class="btn btn-danger" style="padding:0.3rem 0.7rem;font-size:0.78rem;">
                                &#128682; Check Out
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (activeVisits.Count > 10)
        {
            <div style="text-align:center;padding:0.75rem;font-size:0.82rem;color:var(--gray-400);">
                Showing 10 of @activeVisits.Count —
                <a asp-action="ActiveVisits" style="color:var(--blue-600);font-weight:600;">View all</a>
            </div>
        }
    }
    else
    {
        <div class="empty"><span class="empty-icon">&#127968;</span>No visitors currently inside.</div>
    }
</div>