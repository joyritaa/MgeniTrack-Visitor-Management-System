<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MgeniTrack</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MgeniTrack.styles.css" asp-append-version="true" />
</head>
<body>

    @if (User?.Identity?.IsAuthenticated == true)
    {
        <!-- Sidebar -->
        <div class="sidebar">
            <div class="text-center text-white mb-4">
                <h4>MgeniTrack</h4>
                <small>Access Management</small>
            </div>

            <ul class="nav flex-column px-3">

                @* Super Admin *@
                @if (User?.IsInRole("SuperAdmin") == true)
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="AdminDashboard" asp-action="Index">Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Users" asp-action="Index">Manage Users</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Roles" asp-action="Index">Manage Roles</a>
                    </li>
                }

                @* Property Manager *@
                @if (User?.IsInRole("PropertyManager") == true)
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="ManagerDashboard" asp-action="Index">Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Residents" asp-action="Index">Residents</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="VisitorInvitations" asp-action="Index">Invitations</a>
                    </li>
                }

                @* Guard *@
                @if (User?.IsInRole("Guard") == true)
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="GuardDashboard" asp-action="Index">Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Visits" asp-action="Create">Check In</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Visits" asp-action="Index">Active Visits</a>
                    </li>
                }

                @* Resident *@
                @if (User?.IsInRole("Resident") == true)
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="ResidentDashboard" asp-action="Index">My Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="VisitorInvitations" asp-action="Create">Invite Visitor</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="VisitorInvitations" asp-action="Index">My Invitations</a>
                    </li>
                }

            </ul>
        </div>

        <!-- Main Content -->
        <div class="main-content">
            <!-- Top Bar -->
            <div class="topbar d-flex justify-content-between align-items-center">
                <span>
                    Welcome, <strong>@(User?.Identity?.Name ?? "Unknown")</strong>
                </span>
                <a class="btn btn-outline-danger btn-sm" asp-controller="Account" asp-action="Logout">
                    Logout
                </a>
            </div>

            <div class="mt-4">
                @RenderBody()
            </div>
        </div>
    }
    else
    {
        <!-- If not logged in, show normal layout -->
        <div class="container">
            <main role="main" class="pb-3 mt-5">
                @RenderBody()
            </main>
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
