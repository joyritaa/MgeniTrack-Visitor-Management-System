<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — MgeniTrack</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    @if (User?.Identity?.IsAuthenticated == true)
    {
        <!--Sidebar -->
        <aside class="sidebar">

            <!-- Brand -->
            <a class="sidebar-brand" asp-controller="Account" asp-action="Login">
                <div class="sidebar-brand-icon">
                    <svg viewBox="0 0 24 24">
                        <path d="M12 2L3 7v5c0 5.25 3.75 10.15 9 11.25C17.25 22.15 21 17.25 21 12V7L12 2z" />
                        <polyline points="9 12 11 14 15 10" />
                    </svg>
                </div>
                <div class="sidebar-brand-text">
                    <div class="name">MgeniTrack</div>
                    <div class="sub">Access Management</div>
                </div>
            </a>

            <!-- Nav -->
            <span class="sidebar-label">Navigation</span>
            <ul class="nav flex-column">

                @* Super Admin *@
                @if (User?.IsInRole("SuperAdmin") == true)
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="AdminDashboard" asp-action="Index">
                            <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /></svg>
                            Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Users" asp-action="Index">
                            <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
                            Manage Users
                        </a>
                    </li>
                }

                @* Property Manager *@
                @if (User?.IsInRole("PropertyManager") == true)
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="ManagerDashboard" asp-action="Index">
                            <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /></svg>
                            Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Residents" asp-action="Index">
                            <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>
                            Residents
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="VisitorInvitations" asp-action="Index">
                            <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.56 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 5.61 5.61l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" /></svg>
                            Invitations
                        </a>
                    </li>
                }

                @* Guard *@
                @if (User?.IsInRole("Guard") == true)
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="GuardDashboard" asp-action="Index">
                            <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /></svg>
                            Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="VisitorInvitations" asp-action="PendingList">
                            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="16" /><line x1="8" y1="12" x2="16" y2="12" /></svg>
                            Verify Visitor
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Visits" asp-action="Index">
                            <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /><polyline points="10 9 9 9 8 9" /></svg>
                            Active Visits
                        </a>
                    </li>
                }

                @* Resident *@
                @if (User?.IsInRole("Resident") == true)
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="ResidentDashboard" asp-action="Index">
                            <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /></svg>
                            My Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="VisitorInvitations" asp-action="Create">
                            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="16" /><line x1="8" y1="12" x2="16" y2="12" /></svg>
                            Invite Visitor
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="VisitorInvitations" asp-action="Index">
                            <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.56 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 5.61 5.61l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" /></svg>
                            My Invitations
                        </a>
                    </li>
                }

            </ul>

            <!-- Logout -->
            <div class="sidebar-footer">
                <a class="logout-btn" asp-controller="Account" asp-action="Logout">
                    <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                        <polyline points="16 17 21 12 16 7" />
                        <line x1="21" y1="12" x2="9" y2="12" />
                    </svg>
                    Sign Out
                </a>
            </div>
        </aside>

        <!--Main content -->
        <div class="main-content">

            <!-- Topbar -->
            <header class="topbar">
                <div class="topbar-left">
                    <span class="topbar-greeting">
                        Welcome back, <strong>@(User?.Identity?.Name ?? "User")</strong>
                    </span>
                </div>
                <div class="topbar-right">
                    @{
                        var emailParts = User?.Identity?.Name?.Split('@');
                        var initials = emailParts?[0]?.Length > 0
                        ? emailParts[0].Substring(0, Math.Min(2, emailParts[0].Length)).ToUpper()
                        : "U";
                    }
                    <div class="topbar-user">
                        <div class="topbar-avatar">@initials</div>
                        <span class="topbar-user-name">@(User?.Identity?.Name)</span>
                    </div>
                </div>
            </header>

            <!-- Page body -->
            <div class="main-body">
                @RenderBody()
            </div>
        </div>
    }
    else
    {
        @RenderBody()
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
