@model IEnumerable<MgeniTrack.Models.User>

@{
    ViewData["Title"] = "Manage Users";
}

<div class="page-header">
    <div class="page-header-left">
        <h2>&#128100; Manage Users</h2>
        <p>All registered system users</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">&#43; Add User</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">&#9989; @TempData["Success"]</div>
}

<div class="table-card">
    <table class="data-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Role</th>
                <th>Gender</th>
                <th>Status</th>
                <th>Created</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                var initials = (item.Firstname?.Length > 0 ? item.Firstname[0].ToString() : "") +
                (item.Secondname?.Length > 0 ? item.Secondname[0].ToString() : "");
                var roleName = item.UserRoles?.FirstOrDefault(ur => ur.UserStatus == "Active")?.Role?.RoleName ?? "—";
                <tr>
                    <td>
                        <div style="display:flex;align-items:center;gap:0.6rem;">
                            <div class="avatar avatar-sm">@initials.ToUpper()</div>
                            <strong>@item.Firstname @item.Secondname</strong>
                        </div>
                    </td>
                    <td>@item.Email</td>
                    <td>@(item.PhoneNumber ?? "—")</td>
                    <td><span class="badge badge-role">@roleName</span></td>
                    <td>@(item.Gender ?? "—")</td>
                    <td>
                        <span class="badge @(item.UserStatus == "Active" ? "badge-active" : "badge-inactive")">
                            @item.UserStatus
                        </span>
                    </td>
                    <td>@(item.CreatedAt?.ToString("dd MMM yyyy") ?? "—")</td>
                    <td class="table-actions">
                        <a asp-action="Edit" asp-route-id="@item.UserId" class="edit">Edit</a>
                        <a asp-action="Details" asp-route-id="@item.UserId" class="detail">View</a>
                        <a asp-action="Delete" asp-route-id="@item.UserId" class="delete">Deactivate</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
