@model MgeniTrack.Models.User

@{
    ViewData["Title"] = "Deactivate User";
}

<div class="panel" style="max-width:700px;margin:auto;">

    <!-- HEADER -->
    <div style="display:flex;justify-content:space-between;align-items:center;">
        <div>
            <h2 style="margin-bottom:0.2rem;">Deactivate User</h2>
            <p style="opacity:0.7;font-size:0.9rem;">
                This will disable the user’s access to the system
            </p>
        </div>
        <div style="font-size:2.5rem;opacity:0.3;">⚠️</div>
    </div>

    <hr />

    <!-- USER CARD -->
    <div style="display:flex;gap:1rem;align-items:center;margin-bottom:1rem;">
        <div style="
            width:55px;height:55px;border-radius:50%;
            background:#3b82f6;color:white;
            display:flex;align-items:center;justify-content:center;
            font-weight:700;font-size:1.2rem;">
            @Model.Firstname.Substring(0, 1)@Model.Secondname.Substring(0, 1)
        </div>

        <div>
            <div style="font-size:1.2rem;font-weight:700;">
                @Model.Firstname @Model.Secondname
            </div>
            <div style="font-size:0.85rem;color:gray;">
                @Model.Email
            </div>
        </div>
    </div>

    <!-- DETAILS GRID -->
    <div style="
        display:grid;
        grid-template-columns:1fr 1fr;
        gap:0.75rem;
        font-size:0.85rem;
        margin-bottom:1rem;
        ">

        <div>
            <strong>ID Number</strong><br />
            @Model.IdNumber
        </div>

        <div>
            <strong>Phone</strong><br />
            @Model.PhoneNumber
        </div>

        <div>
            <strong>Gender</strong><br />
            @Model.Gender
        </div>

        <div>
            <strong>Status</strong><br />
            <span class="badge @(Model.UserStatus == "Active" ? "badge-green" : "badge-gray")">
                @Model.UserStatus
            </span>
        </div>

        <div>
            <strong>Created</strong><br />
            @(Model.CreatedAt?.ToString("dd MMM yyyy") ?? "—")
        </div>

        <div>
            <strong>Last Login</strong><br />
            @(Model.LastLogin?.ToString("dd MMM yyyy HH:mm") ?? "Never")
        </div>

    </div>

    <!-- warn box -->
    <div style="
        background:#fef2f2;
        border:1px solid #fecaca;
        border-radius:10px;
        padding:0.75rem;
        margin-bottom:1rem;
        font-size:0.8rem;
        color:#b91c1c;
        ">
        ⚠️ This action will disable the user’s account. They will not be able to log in.
    </div>

    <!-- actions -->
    <form asp-action="Delete">
        <input type="hidden" asp-for="UserId" />

        <div style="display:flex;justify-content:space-between;">
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>

            <button type="submit" class="btn btn-danger">
                Deactivate User
            </button>
        </div>
    </form>

</div>