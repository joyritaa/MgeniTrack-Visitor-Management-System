@model MgeniTrack.Models.User

@{
    ViewData["Title"] = "User Profile";
}

<div class="panel" style="max-width:900px;margin:auto;">

    <div style="display:flex;justify-content:space-between;align-items:center;">
        <h2 style="margin:0;">User Profile</h2>

        <span class="badge @(Model.UserStatus == "Active" ? "badge-green" : "badge-red")">
            @Model.UserStatus
        </span>
    </div>

    <hr />

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">

        <div>
            <strong>First Name</strong>
            <div>@Model.Firstname</div>
        </div>

        <div>
            <strong>Second Name</strong>
            <div>@Model.Secondname</div>
        </div>

        <div>
            <strong>Email</strong>
            <div>@Model.Email</div>
        </div>

        <div>
            <strong>Phone</strong>
            <div>@Model.PhoneNumber</div>
        </div>

        <div>
            <strong>ID Number</strong>
            <div>@Model.IdNumber</div>
        </div>

        <div>
            <strong>Gender</strong>
            <div>@Model.Gender</div>
        </div>

        <div>
            <strong>Created At</strong>
            <div>@Model.CreatedAt?.ToString("dd MMM yyyy")</div>
        </div>

        <div>
            <strong>Last Login</strong>
            <div>@Model.LastLogin?.ToString("dd MMM yyyy HH:mm")</div>
        </div>

    </div>

    <div style="margin-top:1.5rem;display:flex;gap:1rem;">
        <a asp-action="Edit" asp-route-id="@Model.UserId" class="btn btn-primary">
            Edit User
        </a>

        <a asp-action="Index" class="btn btn-secondary">
            Back
        </a>
    </div>

</div>