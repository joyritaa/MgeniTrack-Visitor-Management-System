@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container py-5">
    <div class="card shadow border-0 rounded-4">
        <div class="card-body p-5">

            <h1 class="fw-bold mb-4">Privacy Policy</h1>

            <p>
                MgeniTrack values the privacy and security of all residents,
                visitors, and staff using the system.
            </p>

            <h4 class="mt-4">Information We Collect</h4>

            <ul>
                <li>Visitor names</li>
                <li>Phone numbers</li>
                <li>Vehicle registrations</li>
                <li>Visit history</li>
                <li>Login activity</li>
            </ul>

            <h4 class="mt-4">How Data Is Used</h4>

            <p>
                Data is used strictly for:
            </p>

            <ul>
                <li>Security monitoring</li>
                <li>Visitor management</li>
                <li>Audit reporting</li>
                <li>Compliance reviews</li>
            </ul>

            <h4 class="mt-4">Data Protection</h4>

            <p>
                MgeniTrack implements authentication,
                role-based access control,
                audit logging,
                and encrypted passwords to protect user data.
            </p>

        </div>
    </div>
</div>