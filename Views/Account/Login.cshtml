@using MgeniTrack.ViewModels
@model LoginViewModel

@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MgeniTrack — Sign In</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="login-page">

    <div class="login-wrapper">

        <!-- Brand -->
        <div class="login-brand">
            <div class="login-brand-icon">
                <svg viewBox="0 0 24 24">
                    <path d="M12 2L3 7v5c0 5.25 3.75 10.15 9 11.25C17.25 22.15 21 17.25 21 12V7L12 2z" />
                    <polyline points="9 12 11 14 15 10" />
                </svg>
            </div>
            <h1>Mgeni<span>Track</span></h1>
            <p>Digital Visitor Management System</p>
        </div>

        <!-- Card -->
        <div class="login-card">
            <p class="login-card-title">Secure Sign In</p>

            <form asp-controller="Account" asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="alert-danger"></div>

                <div class="form-group">
                    <label asp-for="Email">Email Address</label>
                    <div class="login-input-wrap">
                        <svg viewBox="0 0 24 24">
                            <rect x="2" y="4" width="20" height="16" rx="2" />
                            <polyline points="22,4 12,13 2,4" />
                        </svg>
                        <input asp-for="Email" class="form-control"
                               placeholder="you@example.com" autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email" class="field-error text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Password">Password</label>
                    <div class="login-input-wrap">
                        <svg viewBox="0 0 24 24">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                        </svg>
                        <input asp-for="Password" type="password" class="form-control"
                               placeholder="••••••••" autocomplete="current-password" />
                    </div>
                    <span asp-validation-for="Password" class="field-error text-danger"></span>
                </div>

                <button type="submit" class="btn-login">Sign In</button>
            </form>
        </div>

        <div class="login-footer">
            MgeniTrack DVMS &nbsp;|&nbsp; <span>Kuwa Safe!!</span> &nbsp;|&nbsp; &copy; 2026
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
