@model MgeniTrack.ViewModels.GuardCheckInViewModel

@{
    ViewData["Title"] = "Check In Visitor";
}

<div class="page-header">
    <div class="page-header-left">
        <h2>&#9989; Check In Visitor</h2>
        <p>Verify the visitor's identity and confirm entry</p>
    </div>
    <a asp-action="PendingList" class="btn btn-secondary">&#8592; Back to List</a>
</div>

<!-- Visitor summary banner - guard sees at a glance who is expected -->
<div style="background: var(--blue-50); border: 1.5px solid var(--blue-200);
            border-radius: var(--radius-lg); padding: 1.25rem 1.5rem;
            margin-bottom: 1.5rem; display:flex; gap:1.5rem; flex-wrap:wrap;
            align-items:center;">

    <div style="flex:1; min-width:180px;">
        <div style="font-size:0.7rem; text-transform:uppercase; letter-spacing:0.1em;
                    color:var(--blue-500); font-weight:700; margin-bottom:0.2rem;">
            Expected Visitor
        </div>
        <div style="font-size:1.2rem; font-weight:800; color:var(--blue-800);">
            @Model.VisitorName
        </div>
        <div style="font-size:0.82rem; color:var(--gray-500); margin-top:0.2rem;">
            @(Model.VisitorPhone ?? "No phone provided")
        </div>
    </div>

    <div style="flex:1; min-width:140px;">
        <div style="font-size:0.7rem; text-transform:uppercase; letter-spacing:0.1em;
                    color:var(--blue-500); font-weight:700; margin-bottom:0.2rem;">
            Visiting
        </div>
        <div style="font-size:1rem; font-weight:700; color:var(--blue-800);">
            @Model.ResidentName
        </div>
        <div style="font-size:0.82rem; color:var(--gray-500);">
            House @Model.HouseNumber
        </div>
    </div>

    <div style="flex:1; min-width:140px;">
        <div style="font-size:0.7rem; text-transform:uppercase; letter-spacing:0.1em;
                    color:var(--blue-500); font-weight:700; margin-bottom:0.2rem;">
            Purpose
        </div>
        <div style="font-size:0.9rem; font-weight:600; color:var(--blue-800);">
            @Model.PurposeOfVisit
        </div>
        <div style="font-size:0.82rem; color:var(--gray-500);">
            Expected: @(Model.ExpectedDate?.ToString("dd MMM yyyy") ?? "—")
        </div>
    </div>

</div>

<!-- Check-in form -->
<div class="form-card">
    <div style="font-size:0.78rem; font-weight:700; text-transform:uppercase;
                letter-spacing:0.1em; color:var(--gray-400); margin-bottom:1.25rem;
                padding-bottom:0.75rem; border-bottom:1px solid var(--gray-100);">
        &#128274; Gate Verification Details
    </div>

    <form asp-action="CheckIn" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="InvitationId" />
        <input type="hidden" asp-for="VisitorName" />
        <input type="hidden" asp-for="VisitorPhone" />
        <input type="hidden" asp-for="PurposeOfVisit" />
        <input type="hidden" asp-for="HouseNumber" />
        <input type="hidden" asp-for="ResidentName" />

        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <!-- ID Number -->
        <div class="form-group">
            <label asp-for="IdNumber">Visitor ID / Passport Number</label>
            <input asp-for="IdNumber" class="form-control"
                   placeholder="Enter national ID or passport number" />
            <span asp-validation-for="IdNumber" class="text-danger"></span>
        </div>

        <!-- Occupants + Car reg row -->
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
            <div class="form-group">
                <label asp-for="NumberOfOccupants"></label>
                <input asp-for="NumberOfOccupants" type="number"
                       class="form-control" min="1" max="20" />
                <span asp-validation-for="NumberOfOccupants" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CarRegistration"></label>
                <input asp-for="CarRegistration" class="form-control"
                       placeholder="e.g. KCA 123A (optional)" />
                <span asp-validation-for="CarRegistration" class="text-danger"></span>
            </div>
        </div>

        <!-- Check-in method -->
        <div class="form-group">
            <label asp-for="CheckInMethod"></label>
            <select asp-for="CheckInMethod" class="form-control">
                <option value="Manual">Manual (written verification)</option>
                <option value="QR">QR Code Scan</option>
            </select>
        </div>

        <!-- Photo capture with camera -->
        <div class="form-group">
            <label>Visitor Photo <span style="color:var(--gray-400);font-weight:400;">(optional)</span></label>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 0.5rem;">
                <div>
                    <input type="file" id="photoFileInput" name="visitorPhoto" accept="image/*" class="form-control"
                           style="padding:0.5rem;" onchange="previewPhoto(this)" />
                    <small style="color: var(--gray-500);">Upload from device</small>
                </div>
                <div>
                    <button type="button" class="btn btn-secondary" onclick="captureFromCamera()" style="width: 100%;">
                        📷 Capture Photo
                    </button>
                    <small style="color: var(--gray-500);">Use device camera</small>
                </div>
            </div>
            <img id="photoPreview" src="" style="display:none;width:80px;height:80px;
                 border-radius:50%;object-fit:cover;margin-top:0.5rem;
                 border:2px solid var(--blue-200);" />
        </div>

        <!-- Confirm button -->
        <div style="display:flex; gap:0.75rem; margin-top:1rem;
                    padding-top:1rem; border-top:1px solid var(--gray-100);">
            <button type="submit" class="btn btn-primary" style="flex:1;">
                &#9989; Confirm Check-In
            </button>
            <a asp-action="PendingList" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        let cameraStream = null;

        function previewPhoto(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    var img = document.getElementById('photoPreview');
                    img.src = e.target.result;
                    img.style.display = 'block';
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        function captureFromCamera() {
            let modal = document.getElementById('cameraModal');
            if (!modal) {
                createCameraModal();
                modal = document.getElementById('cameraModal');
            }
            modal.style.display = 'block';
            startCamera();
        }

        function createCameraModal() {
            const modalHTML = `
                <div id="cameraModal" class="modal" style="display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.4);">
                    <div class="modal-content" style="background-color: #fefefe; margin: 10% auto; padding: 20px; border: 1px solid #888; width: 90%; max-width: 500px; border-radius: 8px;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                            <h3 style="margin: 0;">Capture Visitor Photo</h3>
                            <span class="close" onclick="closeCameraModal()" style="font-size: 28px; font-weight: bold; cursor: pointer; color: #aaa;">×</span>
                        </div>
                        <video id="cameraVideo" style="width: 100%; height: auto; border-radius: 4px; margin-bottom: 1rem; background: #000;"></video>
                        <canvas id="photoCanvas" style="display: none;"></canvas>
                        <div style="display: flex; gap: 0.5rem; justify-content: space-between;">
                            <button type="button" class="btn btn-primary" onclick="capturePhoto()" style="flex: 1;">📸 Capture</button>
                            <button type="button" class="btn btn-secondary" onclick="closeCameraModal()" style="flex: 1;">Close</button>
                        </div>
                    </div>
                </div>
            `;
            document.body.insertAdjacentHTML('beforeend', modalHTML);
        }

        function startCamera() {
            const video = document.getElementById('cameraVideo');
            navigator.mediaDevices.getUserMedia({ 
                video: { facingMode: 'user' },
                audio: false
            }).then(stream => {
                cameraStream = stream;
                video.srcObject = stream;
                video.play();
            }).catch(err => {
                alert('Unable to access camera: ' + err.message);
                closeCameraModal();
            });
        }

        function capturePhoto() {
            const video = document.getElementById('cameraVideo');
            const canvas = document.getElementById('photoCanvas');
            const ctx = canvas.getContext('2d');

            canvas.width = video.videoWidth;
            canvas.height = video.videoHeight;
            ctx.drawImage(video, 0, 0);

            canvas.toBlob(blob => {
                const file = new File([blob], 'captured_photo.jpg', { type: 'image/jpeg' });
                const dataTransfer = new DataTransfer();
                dataTransfer.items.add(file);
                document.getElementById('photoFileInput').files = dataTransfer.files;

                const reader = new FileReader();
                reader.onload = function(e) {
                    var img = document.getElementById('photoPreview');
                    img.src = e.target.result;
                    img.style.display = 'block';
                };
                reader.readAsDataURL(blob);

                closeCameraModal();
            }, 'image/jpeg', 0.95);
        }

        function closeCameraModal() {
            const modal = document.getElementById('cameraModal');
            if (modal) modal.style.display = 'none';

            if (cameraStream) {
                cameraStream.getTracks().forEach(track => track.stop());
                cameraStream = null;
            }
        }

        window.onclick = function(event) {
            const modal = document.getElementById('cameraModal');
            if (modal && event.target === modal) {
                closeCameraModal();
            }
        }
    </script>
}

