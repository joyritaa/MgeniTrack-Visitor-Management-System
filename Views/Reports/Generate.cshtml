@{
    ViewData["Title"] = "Generate Report";
}

<div class="page-header">
    <div class="page-header-left">
        <h2>&#128202; Generate Report</h2>
        <p>Select a date range and report type to generate a visitor report</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary">&#128203; View Past Reports</a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">&#9888; @TempData["Error"]</div>
}

<div style="display:grid; grid-template-columns:1fr 1fr; gap:1.5rem; align-items:start;">

    <div class="form-card" style="max-width:100%;">
        <div style="font-size:0.73rem; font-weight:700; text-transform:uppercase;
                    letter-spacing:0.1em; color:var(--gray-400);
                    padding-bottom:0.85rem; margin-bottom:1.25rem;
                    border-bottom:1px solid var(--gray-100);">
            &#9881; Report Configuration
        </div>

        <form asp-action="Generate" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label>Report Type</label>
                <select name="reportType" class="form-control">
                    <option value="Visitor Summary">Visitor Summary</option>
                    <option value="Daily Activity">Daily Activity</option>
                    <option value="Check-In Log">Check-In Log</option>
                    <option value="Security Audit">Security Audit</option>
                </select>
            </div>

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
                <div class="form-group">
                    <label>Date From</label>
                    <input type="date" name="dateFrom" class="form-control"
                           value="@ViewBag.DateFrom"
                           max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                </div>
                <div class="form-group">
                    <label>Date To</label>
                    <input type="date" name="dateTo" class="form-control"
                           value="@ViewBag.DateTo"
                           max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                </div>
            </div>

            <div class="form-group">
                <label>Output Format</label>
                <select name="format" class="form-control">
                    <option value="csv">CSV (Excel-compatible)</option>
                    <option value="html">HTML Preview</option>
                </select>
            </div>

            <div style="display:flex; gap:0.75rem; margin-top:1rem;
                        padding-top:1rem; border-top:1px solid var(--gray-100);">
                <button type="submit" class="btn btn-primary" style="flex:1;">
                    &#128202; Generate Report
                </button>
            </div>
        </form>
    </div>

    <!-- Info panel -->
    <div>
        <div class="panel" style="background:var(--blue-50); border-color:var(--blue-200); margin-bottom:1rem;">
            <div class="panel-title" style="color:var(--blue-500);">&#128274; Report Types</div>
            <div style="font-size:0.83rem; color:var(--blue-700); line-height:2;">
                <div><strong>Visitor Summary</strong> — unique visitors, total visits, top houses</div>
                <div><strong>Daily Activity</strong> — check-ins and check-outs per day</div>
                <div><strong>Check-In Log</strong> — full list of all visitor entries</div>
                <div><strong>Security Audit</strong> — all entries with guard and method details</div>
            </div>
        </div>

        <div class="panel" style="background:var(--success-light); border-color:#a7f3d0;">
            <div class="panel-title" style="color:var(--success-dark);">&#9989; CSV Format</div>
            <p style="font-size:0.83rem; color:var(--success-dark); line-height:1.7;">
                CSV files open directly in Microsoft Excel or Google Sheets.
                They include a summary header and a full row-by-row visit log.
            </p>
        </div>
    </div>
</div>

