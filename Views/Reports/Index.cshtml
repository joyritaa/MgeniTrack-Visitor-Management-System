@model IEnumerable<MgeniTrack.Models.Report>

@{
    ViewData["Title"] = "Reports";
}

<div class="page-header">
    <div class="page-header-left">
        <h2>&#128202; Reports</h2>
        <p>All generated visitor reports</p>
    </div>
    <a asp-action="Generate" class="btn btn-primary">&#43; Generate New Report</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">&#9989; @TempData["Success"]</div>
}

@if (!Model.Any())
{
    <div class="panel">
        <div class="empty">
            <span class="empty-icon">&#128202;</span>
            No reports generated yet.
            <div style="margin-top:0.75rem;">
                <a asp-action="Generate" class="btn btn-primary">Generate your first report</a>
            </div>
        </div>
    </div>
}
else
{
    <div class="table-card">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Report Type</th>
                    <th>Date Range</th>
                    <th>Visitors</th>
                    <th>Check-Ins</th>
                    <th>Check-Outs</th>
                    <th>Format</th>
                    <th>Generated By</th>
                    <th>Generated At</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td><strong>@(r.ReportType ?? "—")</strong></td>
                        <td>
                            @(r.DateFrom?.ToString("dd MMM yyyy") ?? "—")
                            &nbsp;→&nbsp;
                            @(r.DateTo?.ToString("dd MMM yyyy") ?? "—")
                        </td>
                        <td>@(r.TotalVisitors ?? 0)</td>
                        <td>@(r.TotalCheckIns ?? 0)</td>
                        <td>@(r.TotalCheckOuts ?? 0)</td>
                        <td>
                            <span class="badge badge-blue">@(r.FileFormat ?? "CSV")</span>
                        </td>
                        <td>@(r.GeneratedByNavigation?.Firstname ?? "—")</td>
                        <td>@(r.GeneratedAt?.ToString("dd MMM yyyy HH:mm") ?? "—")</td>
                        <td class="table-actions">
                            <a asp-action="Preview" asp-route-id="@r.ReportId" class="detail">Preview</a>
                            <a asp-action="Download" asp-route-id="@r.ReportId" class="edit">&#8595; CSV</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

