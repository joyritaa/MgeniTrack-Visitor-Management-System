@{
    ViewData["Title"] = "Report Preview";
    var report = ViewBag.Report as MgeniTrack.Models.Report;
    var visits = ViewBag.Visits as List<MgeniTrack.Models.Visit>;
}

<div class="page-header">
    <div class="page-header-left">
        <h2>&#128202; @(report?.ReportType ?? "Report") Preview</h2>
        <p>
            @(report?.DateFrom?.ToString("dd MMM yyyy")) — @(report?.DateTo?.ToString("dd MMM yyyy"))
            &nbsp;•&nbsp; Generated by @(report?.GeneratedByNavigation?.Firstname)
            at @(report?.GeneratedAt?.ToString("HH:mm, dd MMM yyyy"))
        </p>
    </div>
    <div style="display:flex; gap:0.65rem;">
        <a asp-action="Download" asp-route-id="@report?.ReportId"
           class="btn btn-primary">&#8595; Download CSV</a>
        <a asp-action="Index" class="btn btn-secondary">&#8592; All Reports</a>
    </div>
</div>

<!-- Summary stats -->
<div class="stats-grid" style="grid-template-columns: repeat(3, 1fr); margin-bottom:1.5rem;">
    <div class="stat-card blue">
        <div class="stat-icon">&#128118;</div>
        <div class="stat-info">
            <div class="value">@(report?.TotalVisitors ?? 0)</div>
            <div class="label">Unique Visitors</div>
        </div>
    </div>
    <div class="stat-card green">
        <div class="stat-icon">&#9989;</div>
        <div class="stat-info">
            <div class="value">@(report?.TotalCheckIns ?? 0)</div>
            <div class="label">Total Check-Ins</div>
        </div>
    </div>
    <div class="stat-card orange">
        <div class="stat-icon">&#128682;</div>
        <div class="stat-info">
            <div class="value">@(report?.TotalCheckOuts ?? 0)</div>
            <div class="label">Total Check-Outs</div>
        </div>
    </div>
</div>

<!-- Visit log table -->
<div class="panel">
    <div class="panel-title">&#128203; Visit Log</div>

    @if (visits != null && visits.Any())
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Visitor</th>
                    <th>ID Number</th>
                    <th>House</th>
                    <th>Purpose</th>
                    <th>Method</th>
                    <th>Time In</th>
                    <th>Time Out</th>
                    <th>Duration</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var v in visits)
                {
                    <tr>
                        <td><strong>@(v.Visitor?.FullName ?? "—")</strong></td>
                        <td>@(v.Visitor?.IdNumber ?? "—")</td>
                        <td><span class="badge badge-blue">@(v.HouseNumber ?? "—")</span></td>
                        <td>@(v.PurposeOfVisit ?? "—")</td>
                        <td>
                            <span class="badge @(v.CheckInMethod == "QR" ? "badge-blue" : "badge-gray")">
                                @(v.CheckInMethod ?? "Manual")
                            </span>
                        </td>
                        <td>@(v.TimeIn?.ToString("dd MMM HH:mm") ?? "—")</td>
                        <td>@(v.TimeOut?.ToString("dd MMM HH:mm") ?? "—")</td>
                        <td>
                            @if (v.VisitDuration.HasValue)
                            {
                                var m = v.VisitDuration.Value;
                                @(m >= 60 ? $"{m / 60}h {m % 60}m" : $"{m}m")
                            }
                            else
                            {

                                <span>—</span>
                            }
                        </td>
                        <td>
                            <span class="badge @(v.VisitStatus == "CheckedIn" ? "badge-in" : "badge-out")">
                                @v.VisitStatus
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="empty">No visits found for this date range.</div>
    }
</div>
