@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="page-header">
    <div class="page-header-left">
        <h2>&#128274; Admin Dashboard</h2>
        <p>System overview — @DateTime.Now.ToString("dddd, dd MMMM yyyy")</p>
    </div>
</div>

<div class="stats-grid">
    <div class="stat-card green">
        <div class="stat-icon">&#128100;</div>
        <div class="stat-info">
            <div class="value">@ViewBag.TotalUsers</div>
            <div class="label">Active Users</div>
        </div>
    </div>
    <div class="stat-card blue">
        <div class="stat-icon">&#127968;</div>
        <div class="stat-info">
            <div class="value">@ViewBag.TotalResidents</div>
            <div class="label">Residents</div>
        </div>
    </div>
    <div class="stat-card orange">
        <div class="stat-icon">&#128737;</div>
        <div class="stat-info">
            <div class="value">@ViewBag.TotalGuards</div>
            <div class="label">Active Guards</div>
        </div>
    </div>
    <div class="stat-card teal">
        <div class="stat-icon">&#128118;</div>
        <div class="stat-info">
            <div class="value">@ViewBag.TotalVisitors</div>
            <div class="label">Total Visitors</div>
        </div>
    </div>
    <div class="stat-card purple">
        <div class="stat-icon">&#128197;</div>
        <div class="stat-info">
            <div class="value">@ViewBag.TotalVisitsToday</div>
            <div class="label">Visits Today</div>
        </div>
    </div>
    <div class="stat-card red">
        <div class="stat-icon">&#128682;</div>
        <div class="stat-info">
            <div class="value">@ViewBag.ActiveVisits</div>
            <div class="label">Currently Inside</div>
        </div>
    </div>
</div>

<div class="panels-2col">
    <div class="panel">
        <div class="panel-title">&#128337; Recent Visits</div>
        @{
            var recentVisits = ViewBag.RecentVisits as List<MgeniTrack.Models.Visit>;
        }
        @if (recentVisits != null && recentVisits.Any())
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Visitor</th>
                        <th>House</th>
                        <th>Time In</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in recentVisits)
                    {
                        <tr>
                            <td><strong>@(v.Visitor?.FullName ?? "—")</strong></td>
                            <td>@(v.HouseNumber ?? "—")</td>
                            <td>@(v.TimeIn?.ToString("dd MMM, HH:mm") ?? "—")</td>
                            <td>
                                @if (v.VisitStatus == "CheckedIn")
                                {
                                    <span class="badge badge-in">&#9679; Inside</span>
                                }
                                else
                                {
                                    <span class="badge badge-out">Checked Out</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="empty"><span class="empty-icon">&#128203;</span>No visits recorded yet.</div>
        }
    </div>

    <div class="panel">
        <div class="panel-title">&#127381; Recently Added Users</div>
        @{
            var recentUsers = ViewBag.RecentUsers as List<MgeniTrack.Models.User>;
        }
        @if (recentUsers != null && recentUsers.Any())
        {
            @foreach (var u in recentUsers)
            {
                var initials = (u.Firstname?.Length > 0 ? u.Firstname[0].ToString() : "") +
                (u.Secondname?.Length > 0 ? u.Secondname[0].ToString() : "");
                var roleName = u.UserRoles?.FirstOrDefault(ur => ur.UserStatus == "Active")?.Role?.RoleName ?? "—";
                <div class="user-row">
                    <div class="avatar avatar-md">@initials.ToUpper()</div>
                    <div class="user-info">
                        <div class="name">@u.Firstname @u.Secondname</div>
                        <div class="role">@roleName</div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty">No users yet.</div>
        }
    </div>
</div>
