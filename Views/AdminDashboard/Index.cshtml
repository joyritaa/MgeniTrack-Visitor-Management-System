@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="page-header">
    <div class="page-header-left">
        <h2>&#128274; Admin Dashboard</h2>
        <p>@DateTime.Now.ToString("dddd, dd MMMM yyyy")</p>
    </div>
    <div style="display:flex;gap:0.65rem;">
        <a asp-controller="Reports" asp-action="Generate" class="btn btn-primary">&#128202; Generate Report</a>
        <a asp-action="ActivityLogs" class="btn btn-secondary">&#128396; Activity Logs</a>
    </div>
</div>

<div class="stats-grid">
    <div class="stat-card green">
        <div class="stat-icon">&#128100;</div>
        <div class="stat-info"><div class="value">@ViewBag.TotalUsers</div><div class="label">Active Users</div></div>
    </div>
    <div class="stat-card blue">
        <div class="stat-icon">&#127968;</div>
        <div class="stat-info"><div class="value">@ViewBag.TotalResidents</div><div class="label">Residents</div></div>
    </div>
    <div class="stat-card orange">
        <div class="stat-icon">&#128737;</div>
        <div class="stat-info"><div class="value">@ViewBag.TotalGuards</div><div class="label">Guards</div></div>
    </div>
    <div class="stat-card teal">
        <div class="stat-icon">&#128118;</div>
        <div class="stat-info"><div class="value">@ViewBag.TotalVisitors</div><div class="label">Total Visitors</div></div>
    </div>
    <div class="stat-card purple">
        <div class="stat-icon">&#128197;</div>
        <div class="stat-info"><div class="value">@ViewBag.TotalVisitsToday</div><div class="label">Visits Today</div></div>
    </div>
    <div class="stat-card red">
        <div class="stat-icon">&#128682;</div>
        <div class="stat-info"><div class="value">@ViewBag.ActiveVisits</div><div class="label">Currently Inside</div></div>
    </div>
</div>

<!-- Unit occupancy bar -->
@{
    int occupied = ViewBag.OccupiedUnits ?? 0;
    int total = ViewBag.TotalUnits ?? 180;
    int pct = total > 0 ? (int)((occupied / (double)total) * 100) : 0;
}
<div class="panel" style="margin-bottom:1.25rem;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.65rem;">
        <span style="font-size:0.78rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--gray-400);">
            &#127968; Unit Occupancy
        </span>
        <span style="font-size:0.85rem;font-weight:700;color:var(--blue-700);">
            @occupied / @total units occupied (@pct%)
        </span>
    </div>
    <div style="background:var(--gray-100);border-radius:20px;height:10px;overflow:hidden;">
        <div style="width:@pct%;height:100%;background:linear-gradient(90deg,var(--blue-500),var(--blue-400));border-radius:20px;transition:width 0.5s;"></div>
    </div>
</div>

<div class="panels-2col">


    <!-- Recent Visits -->
    <div class="panel">
        <div class="panel-title">&#128337; Recent Visits</div>
        @{
            var recentVisits = ViewBag.RecentVisits as List<MgeniTrack.Models.Visit>;
        }
        @if (recentVisits != null && recentVisits.Any())
        {
            <table class="data-table">
                <thead><tr><th>Visitor</th><th>House</th><th>Time In</th><th>Status</th></tr></thead>
                <tbody>
                    @foreach (var v in recentVisits)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(v.Visitor?.PhotoUrl))
                                {
                                    <img src="@v.Visitor.PhotoUrl" style="width:24px;height:24px;border-radius:50%;object-fit:cover;margin-right:0.35rem;vertical-align:middle;" />
                                }
                                <strong>@(v.Visitor?.FullName ?? "—")</strong>
                            </td>
                            <td><span class="badge @(v.HouseNumber?.StartsWith("C") == true ? "badge-purple" : "badge-blue")">@(v.HouseNumber ?? "—")</span></td>
                            <td>@(v.TimeIn?.ToString("dd MMM, HH:mm") ?? "—")</td>
                            <td><span class="badge @(v.VisitStatus == "CheckedIn" ? "badge-in" : "badge-out")">@v.VisitStatus</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {

            <div class="empty"><span class="empty-icon">&#128203;</span>No visits yet.</div>
        }
    </div>

    <!-- Recent Users -->
    <div class="panel">
        <div style="display:flex;justify-content:space-between;align-items:center;padding-bottom:0.85rem;margin-bottom:1rem;border-bottom:1px solid var(--gray-100);">
            <span class="panel-title" style="border:none;padding:0;margin:0;">&#127381; Recent Users</span>
            <a asp-controller="Users" asp-action="Create" style="font-size:0.78rem;color:var(--blue-600);font-weight:600;">+ Add User</a>
        </div>
        @{
            var recentUsers = ViewBag.RecentUsers as List<MgeniTrack.Models.User>;
        }
        @if (recentUsers != null && recentUsers.Any())
        {
            @foreach (var u in recentUsers)
            {
                var initials = $"{u.Firstname?[0]}{u.Secondname?[0]}".ToUpper();
                var role = u.UserRoles?.FirstOrDefault(ur => ur.UserStatus == "Active")?.Role?.RoleName ?? "—";
                var shift = u.UserRoles?.FirstOrDefault(ur => ur.UserStatus == "Active")?.Shift;
                <div class="user-row">
                    <div class="avatar avatar-md">@initials</div>
                    <div class="user-info" style="flex:1;">
                        <div class="name">@u.Firstname @u.Secondname</div>
                        <div class="role">@role @(shift != null ? $"· {shift} shift" : "")</div>
                    </div>
                    <a asp-action="UserDetails" asp-route-id="@u.UserId"
                       style="font-size:0.75rem;color:var(--blue-600);">View</a>
                </div>
            }
        }
        else
        {
            <div class="empty">No users yet.</div>
        }
    </div>
</div>

<div class="panels-2col">
    <!-- Activity Logs -->
    <div class="panel">
        <div style="display:flex;justify-content:space-between;align-items:center;padding-bottom:0.85rem;margin-bottom:1rem;border-bottom:1px solid var(--gray-100);">
            <span class="panel-title" style="border:none;padding:0;margin:0;">&#128396; Recent Activity</span>
            <a asp-action="ActivityLogs" style="font-size:0.78rem;color:var(--blue-600);font-weight:600;">View All →</a>
        </div>
        @{
            var logs = ViewBag.ActivityLogs as List<MgeniTrack.Models.ActivityLog>;
        }
        @if (logs != null && logs.Any())
        {
            @foreach (var log in logs.Take(12))
            {
                var (icon, color) = log.ActionType switch
                {
                    "Login" => ("&#128275;", "var(--success)"),
                    "Logout" => ("&#128274;", "var(--gray-400)"),
                    "LoginFailed" => ("&#10060;", "var(--danger)"),
                    "CheckIn" => ("&#9989;", "var(--success)"),
                    "CheckOut" => ("&#128682;", "var(--warning)"),
                    "Create" => ("&#10133;", "var(--blue-500)"),
                    "Update" => ("&#9999;", "var(--blue-500)"),
                    "Deactivate" => ("&#128683;", "var(--danger)"),
                    "Report" => ("&#128202;", "var(--purple)"),
                    _ => ("&#9679;", "var(--gray-400)")
                };
                <div style="display:flex;gap:0.65rem;align-items:flex-start;padding:0.55rem 0;border-top:1px solid var(--gray-100);">
                    <div style="width:26px;height:26px;border-radius:50%;background:var(--gray-100);display:flex;align-items:center;justify-content:center;font-size:0.7rem;flex-shrink:0;">
                        @Html.Raw(icon)
                    </div>
                    <div style="flex:1;min-width:0;">
                        <div style="font-size:0.82rem;color:var(--gray-800);">
                            <strong>@(log.User?.Firstname ?? "System")</strong>
                            <span style="color:var(--gray-500);font-weight:400;"> — @(log.ActionDetails ?? log.ActionType)</span>
                        </div>
                    </div>
                    <div style="font-size:0.7rem;color:var(--gray-400);white-space:nowrap;flex-shrink:0;">
                        @(log.TimeStamp?.ToString("dd MMM HH:mm"))
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty"><span class="empty-icon">&#128396;</span>No activity yet. Actions will appear here as users interact with the system.</div>
        }
    </div>

    <!-- Recent Reports -->
    <div class="panel">
        <div style="display:flex;justify-content:space-between;align-items:center;padding-bottom:0.85rem;margin-bottom:1rem;border-bottom:1px solid var(--gray-100);">
            <span class="panel-title" style="border:none;padding:0;margin:0;">&#128202; Recent Reports</span>
            <a asp-controller="Reports" asp-action="Generate" style="font-size:0.78rem;color:var(--blue-600);font-weight:600;">+ Generate</a>
        </div>
        @{
            var reports = ViewBag.RecentReports as List<MgeniTrack.Models.Report>;
        }
        @if (reports != null && reports.Any())
        {
            @foreach (var r in reports)
            {
                <div style="display:flex;justify-content:space-between;align-items:center;padding:0.65rem 0;border-top:1px solid var(--gray-100);">
                    <div>
                        <div style="font-size:0.85rem;font-weight:600;color:var(--gray-800);">@(r.ReportType ?? "Report")</div>
                        <div style="font-size:0.72rem;color:var(--gray-400);">
                            @(r.DateFrom?.ToString("dd MMM")) – @(r.DateTo?.ToString("dd MMM yyyy"))
                            &nbsp;•&nbsp; @(r.TotalCheckIns ?? 0) check-ins
                        </div>
                    </div>
                    <div style="display:flex;gap:0.4rem;">
                        <a asp-controller="Reports" asp-action="Preview" asp-route-id="@r.ReportId"
                           class="btn btn-secondary" style="padding:0.28rem 0.65rem;font-size:0.72rem;">View</a>
                        <a asp-controller="Reports" asp-action="Download" asp-route-id="@r.ReportId"
                           class="btn btn-secondary" style="padding:0.28rem 0.65rem;font-size:0.72rem;">&#8595;</a>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty">
                <span class="empty-icon">&#128202;</span>
                <div style="margin-top:0.5rem;">
                    <a asp-controller="Reports" asp-action="Generate" class="btn btn-primary" style="font-size:0.8rem;">Generate First Report</a>
                </div>
            </div>
        }
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

<script>
    const connection = new signalR.HubConnectionBuilder()
    .withUrl("/dashboardHub")
    .build();

    connection.on("ReceiveDashboardUpdate", function (data) {

    document.getElementById("currentlyInside").innerText = data.currentlyInside;
    document.getElementById("todayVisits").innerText = data.todayVisits;
    document.getElementById("checkedOut").innerText = data.checkedOut;

    let pct = data.total > 0
    ? Math.floor((data.occupied / data.total) * 100)
    : 0;

    document.getElementById("occupancyBar").style.width = pct + "%";
    document.getElementById("occupancyText").innerText = pct + "%";
    });

    connection.start()
    .then(() => console.log("SignalR Connected"))
    .catch(err => console.error(err));
</script>