@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="page-header">
    <div class="page-header-left">
        <h2>&#128274; Admin Dashboard</h2>
        <p>System overview — @DateTime.Now.ToString("dddd, dd MMMM yyyy")</p>
    </div>
    <a asp-controller="Reports" asp-action="Generate" class="btn btn-primary">
        &#128202; Generate Report
    </a>
</div>

<!-- Stats -->
<div class="stats-grid">
    <div class="stat-card green">
        <div class="stat-icon">&#128100;</div>
        <div class="stat-info"><div class="value">@ViewBag.TotalUsers</div><div class="label">Active Users</div></div>
    </div>
    <div class="stat-card blue">
        <div class="stat-icon">&#127968;</div>
        <div class="stat-info"><div class="value">@ViewBag.TotalResidents</div><div class="label">Residents</div></div>
    </div>
    <div class="stat-card orange">
        <div class="stat-icon">&#128737;</div>
        <div class="stat-info"><div class="value">@ViewBag.TotalGuards</div><div class="label">Active Guards</div></div>
    </div>
    <div class="stat-card teal">
        <div class="stat-icon">&#128118;</div>
        <div class="stat-info"><div class="value">@ViewBag.TotalVisitors</div><div class="label">Total Visitors</div></div>
    </div>
    <div class="stat-card purple">
        <div class="stat-icon">&#128197;</div>
        <div class="stat-info"><div class="value">@ViewBag.TotalVisitsToday</div><div class="label">Visits Today</div></div>
    </div>
    <div class="stat-card red">
        <div class="stat-icon">&#128682;</div>
        <div class="stat-info"><div class="value">@ViewBag.ActiveVisits</div><div class="label">Currently Inside</div></div>
    </div>
</div>

<!-- Row 1: Recent Visits + New Users -->
<div class="panels-2col">
    <div class="panel">
        <div class="panel-title">&#128337; Recent Visits</div>
        @{
            var recentVisits = ViewBag.RecentVisits as List<MgeniTrack.Models.Visit>;
        }
        @if (recentVisits != null && recentVisits.Any())
        {
            <table class="data-table">
                <thead>
                    <tr><th>Visitor</th><th>House</th><th>Time In</th><th>Status</th></tr>
                </thead>
                <tbody>
                    @foreach (var v in recentVisits)
                    {
                        <tr>
                            <td><strong>@(v.Visitor?.FullName ?? "—")</strong></td>
                            <td>@(v.HouseNumber ?? "—")</td>
                            <td>@(v.TimeIn?.ToString("dd MMM, HH:mm") ?? "—")</td>
                            <td>
                                <span class="badge @(v.VisitStatus == "CheckedIn" ? "badge-in" : "badge-out")">
                                    @v.VisitStatus
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {

            <div class="empty"><span class="empty-icon">&#128203;</span>No visits yet.</div>
        }
    </div>

    <div class="panel">
        <div class="panel-title">&#127381; Recent Users</div>
        @{
            var recentUsers = ViewBag.RecentUsers as List<MgeniTrack.Models.User>;
        }
        @if (recentUsers != null && recentUsers.Any())
        {
            @foreach (var u in recentUsers)
            {
                var initials = (u.Firstname?.Length > 0 ? u.Firstname[0].ToString() : "") +
                (u.Secondname?.Length > 0 ? u.Secondname[0].ToString() : "");
                var role = u.UserRoles?.FirstOrDefault(ur => ur.UserStatus == "Active")?.Role?.RoleName ?? "—";
                <div class="user-row">
                    <div class="avatar avatar-md">@initials.ToUpper()</div>
                    <div class="user-info">
                        <div class="name">@u.Firstname @u.Secondname</div>
                        <div class="role">@role</div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty">No users yet.</div>
        }
    </div>
</div>

<!-- Row 2: Activity Logs + Recent Reports -->
<div class="panels-2col">

    <!-- Activity Logs -->
    <div class="panel">
        <div style="display:flex; justify-content:space-between; align-items:center;
                    padding-bottom:0.85rem; margin-bottom:1rem;
                    border-bottom:1px solid var(--gray-100);">
            <span style="font-size:0.73rem; font-weight:700; text-transform:uppercase;
                         letter-spacing:0.1em; color:var(--gray-400);">
                &#128396; Activity Logs
            </span>
        </div>
        @{
            var logs = ViewBag.ActivityLogs as List<MgeniTrack.Models.ActivityLog>;
        }
        @if (logs != null && logs.Any())
        {
            @foreach (var log in logs)
            {
                var icon = log.ActionType switch
                {
                    "Login" => "&#128275;",
                    "Logout" => "&#128274;",
                    "CheckIn" => "&#9989;",
                    "CheckOut" => "&#128682;",
                    "Create" => "&#10133;",
                    "Update" => "&#9999;",
                    "Delete" => "&#128465;",
                    _ => "&#9679;"
                };
                <div style="display:flex; gap:0.75rem; align-items:flex-start;
                                    padding:0.6rem 0; border-top:1px solid var(--gray-100);">
                    <div style="width:28px; height:28px; border-radius:50%;
                                        background:var(--blue-100); display:flex;
                                        align-items:center; justify-content:center;
                                        font-size:0.75rem; flex-shrink:0;">
                        @Html.Raw(icon)
                    </div>
                    <div style="flex:1; min-width:0;">
                        <div style="font-size:0.83rem; font-weight:600; color:var(--gray-800);">
                            @(log.User?.Firstname ?? "System")
                            <span style="font-weight:400; color:var(--gray-500);">
                                — @(log.ActionType ?? "Action")
                            </span>
                        </div>
                        <div style="font-size:0.75rem; color:var(--gray-400); margin-top:0.1rem;">
                            @(log.ActionDetails ?? log.RelatedEntityType ?? "")
                        </div>
                    </div>
                    <div style="font-size:0.72rem; color:var(--gray-400); white-space:nowrap; flex-shrink:0;">
                        @(log.TimeStamp?.ToString("dd MMM HH:mm") ?? "—")
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty">
                <span class="empty-icon">&#128396;</span>
                No activity logs yet. Logs are recorded automatically as users interact with the system.
            </div>
        }
    </div>

    <!-- Recent Reports -->
    <div class="panel">
        <div style="display:flex; justify-content:space-between; align-items:center;
                    padding-bottom:0.85rem; margin-bottom:1rem;
                    border-bottom:1px solid var(--gray-100);">
            <span style="font-size:0.73rem; font-weight:700; text-transform:uppercase;
                         letter-spacing:0.1em; color:var(--gray-400);">
                &#128202; Recent Reports
            </span>
            <a asp-controller="Reports" asp-action="Generate"
               style="font-size:0.78rem; font-weight:600; color:var(--blue-600);">
                + New
            </a>
        </div>
        @{
            var reports = ViewBag.RecentReports as List<MgeniTrack.Models.Report>;
        }
        @if (reports != null && reports.Any())
        {
            @foreach (var r in reports)
            {
                <div style="display:flex; justify-content:space-between; align-items:center;
                                    padding:0.65rem 0; border-top:1px solid var(--gray-100);">
                    <div>
                        <div style="font-size:0.85rem; font-weight:600; color:var(--gray-800);">
                            @(r.ReportType ?? "Report")
                        </div>
                        <div style="font-size:0.73rem; color:var(--gray-400);">
                            @(r.DateFrom?.ToString("dd MMM")) – @(r.DateTo?.ToString("dd MMM yyyy"))
                            &nbsp;•&nbsp; @(r.TotalCheckIns ?? 0) check-ins
                        </div>
                    </div>
                    <a asp-controller="Reports" asp-action="Preview" asp-route-id="@r.ReportId"
                       class="btn btn-secondary" style="padding:0.3rem 0.7rem; font-size:0.75rem;">
                        View
                    </a>
                </div>
            }
        }
        else
        {
            <div class="empty">
                <span class="empty-icon">&#128202;</span>
                No reports yet.
                <div style="margin-top:0.5rem;">
                    <a asp-controller="Reports" asp-action="Generate" class="btn btn-primary"
                       style="font-size:0.8rem;">Generate First Report</a>
                </div>
            </div>
        }
    </div>
</div>
