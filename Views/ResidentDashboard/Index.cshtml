@{
    ViewData["Title"] = "My Dashboard";
}

<div class="page-header">
    <div class="page-header-left">
        <h2>&#127968; My Dashboard</h2>
        <p>Manage your visitors and invitations</p>
    </div>
</div>

<div class="house-banner">
    <div>
        <div class="label">Your Unit</div>
        <div class="house-num">House @ViewBag.HouseNumber</div>
    </div>
    <div class="house-icon">&#127968;</div>
</div>

<div class="stats-grid">
    <div class="stat-card blue">
        <div class="stat-icon">&#128140;</div>
        <div class="stat-info">
            <div class="value">@ViewBag.TotalInvitations</div>
            <div class="label">Total Invitations</div>
        </div>
    </div>
    <div class="stat-card green">
        <div class="stat-icon">&#128118;</div>
        <div class="stat-info">
            <div class="value">@ViewBag.ActiveVisitors</div>
            <div class="label">Visitors Arrived</div>
        </div>
    </div>
</div>

<div class="quick-actions">
    <a asp-controller="VisitorInvitations" asp-action="Create" class="btn btn-primary">&#43; Invite a Visitor</a>
    <a asp-controller="VisitorInvitations" asp-action="Index" class="btn btn-secondary">&#128203; My Invitations</a>
</div>

<div class="panel">
    <div class="panel-title">&#128337; Recent Invitations</div>
    @{
        var recent = ViewBag.RecentVisits as List<MgeniTrack.Models.VisitorInvitation>;
    }
    @if (recent != null && recent.Any())
    {
        @foreach (var inv in recent)
        {
            var bc = inv.VisitStatus switch
            {
                "Pending" => "badge-pending",
                "Arrived" => "badge-arrived",
                "Expired" => "badge-expired",
                "Cancelled" => "badge-cancelled",
                _ => "badge-pending"
            };
            <div class="inv-row">
                <div>
                    <div class="inv-name">@inv.VisitorName</div>
                    <div class="inv-meta">@inv.PurposeOfVisit &nbsp;•&nbsp; @(inv.ExpectedDate?.ToString("dd MMM yyyy") ?? "No date")</div>
                </div>
                <span class="badge @bc">@inv.VisitStatus</span>
            </div>
        }
    }
    else
    {
        <div class="empty">You haven't created any invitations yet.</div>
    }
</div>
